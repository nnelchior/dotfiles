[config]
version_check = false

[config.wallpaper]
set = true
command = "swww"
arguments = ["img", "--transition-type", "center", "{{image}}"]


[templates.github]
input_path = "./websites/github.css"
output_path = "~/.config/mozilla/firefox/lf78in4b.default-release/chrome/github-colors.css"

[templates.youtube]
input_path = "./websites/youtube.css"
output_path = "~/.config/mozilla/firefox/lf78in4b.default-release/chrome/youtube-colors.css"


[templates.btop]
input_path = './templates/btop.theme'
output_path = '~/.config/btop/themes/matugen.theme'
post_hook = "sh -c 'pkill -USR2 btop || true'"

[templates.foot]
input_path = './templates/foot-colors.ini'
output_path = '~/.config/foot/themes/matugen.ini'

[templates.emacs]
input_path = './templates/colors.css'
output_path = '~/.config/emacs/colors.css'

[templates.gtk3]
input_path = './templates/gtk-colors.css'
output_path = '~/.config/gtk-3.0/colors.css'
post_hook = 'gsettings set org.gnome.desktop.interface gtk-theme ""; gsettings set org.gnome.desktop.interface gtk-theme adw-gtk3-{{mode}}'

[templates.gtk4]
input_path = './templates/gtk-colors.css'
output_path = '~/.config/gtk-4.0/colors.css'

[templates.helix]
input_path = './templates/helix.toml'
output_path = '~/.config/helix/themes/matugen.toml'

[templates.kvantum_kvconfig]
input_path = './templates/kvantum-colors.kvconfig'
output_path = '~/.config/Kvantum/matugen/matugen.kvconfig'

[templates.kvantum_svg]
input_path = './templates/kvantum-colors.svg'
output_path = '~/.config/Kvantum/matugen/matugen.svg'

[templates.mako]
input_path = './templates/mako'
output_path = '~/.config/mako/mako-colors'
post_hook = 'makoctl reload'

[templates.pywalfox]
input_path = './templates/pywalfox-colors.json'
output_path = '~/.cache/wal/colors.json'
post_hook = 'pywalfox update'

[templates.qt5ct]
input_path = './templates/qtct-colors.conf'
output_path = '~/.config/qt5ct/colors/matugen.conf'

[templates.qt6ct]
input_path = './templates/qtct-colors.conf'
output_path = '~/.config/qt6ct/colors/matugen.conf'

[templates.quickshell]
input_path = './templates/quickshell.qml'
output_path = '~/.config/quickshell/Colors.qml'

[templates.starship]
input_path = './templates/starship-colors.toml'
output_path = '~/.config/starship.toml'

[templates.telegram]
input_path = './templates/telegram.tdesktop-theme'
output_path = '~/Downloads/matugen.tdesktop-theme'

[templates.vesktop]
input_path = './templates/midnight-discord.css'
output_path = '~/.config/vesktop/themes/midnight-discord.css'

[templates.wine]
input_path = './templates/wine.reg'
output_path = '/tmp/wine.reg'
post_hook = 'wine regedit /tmp/wine.reg'

[templates.yazi]
input_path = './templates/yazi-theme.toml'
output_path = '~/.config/yazi/theme.toml'
